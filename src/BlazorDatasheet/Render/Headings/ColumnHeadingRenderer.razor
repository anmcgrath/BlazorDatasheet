@using BlazorDatasheet.DataStructures.Geometry
@using BlazorDatasheet.Formula.Core
@using BlazorDatasheet.Menu
@using BlazorDatasheet.Render.Layers.Preview
@using BlazorDatasheet.Services
@using BlazorDatasheet.Virtualise
@using Microsoft.JSInterop
@inherits HeadingRenderer
@implements IAsyncDisposable
@inject IJSRuntime Js;

<div style="display: flex; flex-direction: row">
    
    @if (_sheet.FreezeState.Left > 0 && HasVisibleCols(LeftHeadingRegion))
    {
        <div style="position: sticky; left:var(--gutter-left-width); z-index: 4;" class="bds-frozen-left">
            <Virtualise2D
                @ref="_leftView"
                LayoutProvider="LayoutProvider"
                OverscanColumns="OverscanColumns"
                ViewRegion="LeftHeadingRegion">
                <GridItemTemplate>
                    @ColHeadingItem(context.col)
                </GridItemTemplate>
            </Virtualise2D>
        </div>
    }

    @if (HasVisibleCols(MainHeadingRegion))
    {
        <div class="bds-sheet-col-head-container" style="z-index: 2;">
            <Virtualise2D
                @ref="MainView"
                LayoutProvider="LayoutProvider"
                OverscanColumns="OverscanColumns"
                ViewRegion="MainHeadingRegion">
                <GridItemTemplate>
                    @ColHeadingItem(context.col)
                </GridItemTemplate>
            </Virtualise2D>
        </div>
    }

    @if (_sheet.FreezeState.Right > 0 && HasVisibleCols(RightHeadingRegion))
    {
        <div style="position: sticky; right: 0; z-index: 4;" class="bds-frozen-right">
            <Virtualise2D
                @ref="_rightView"
                LayoutProvider="LayoutProvider"
                OverscanColumns="OverscanColumns"
                ViewRegion="RightHeadingRegion">
                <GridItemTemplate>
                    @ColHeadingItem(context.col)
                </GridItemTemplate>
            </Virtualise2D>
        </div>
    }
</div>

@code {

    private RenderFragment ColHeadingItem(int col) => @<div
                                                          @key="col"
                                                          style="width: 100%; height: 100%; display: flex; justify-content: start; position: relative; overflow-x: visible;">
                                                          <div
                                                              class="bds-col-head bds-sheet-cell @GetSelectedClass(col)"
                                                              data-col="@col"
                                                              data-row="-1"
                                                              style="display: flex; justify-content: space-between; width: 100%;">
                                                              <div>
                                                                  @ChildContent(new HeadingContext(col, _sheet.Columns.GetHeading(col) ?? RangeText.ColIndexToLetters(col)))
                                                              </div>
                                                              <div style="display: flex; flex-direction: row;">
                                                                  @if (ShowColumnMenu)
                                                                  {
                                                                      <SheetMenuTarget MenuId="@ContextMenus.Selection"
                                                                                       MenuData="Sheet">
                                                                          <CaretButton/>
                                                                      </SheetMenuTarget>
                                                                  }
                                                              </div>
                                                          </div>

                                                          <div class="bds-unselectable"
                                                               @onmousedown="_ => HandleMouseDownOnResizer(col)"
                                                               style="position: absolute;
                 right: 0;
                 z-index: 4;
                 margin-right:-5px;
                 width: 10px;
                 height: 100%;
                 float: left;
                 display: inline-block;
                 cursor: col-resize;">
                                                          </div>
                                                      </div>;

    [Parameter] public bool ShowColumnMenu { get; set; }

    [Parameter] public PreviewService? PreviewService { get; set; }

    private PreviewItem? _resizePreviewItem;

    /// <summary>
    /// The number of columns past the end of the viewport to render.
    /// </summary>
    [Parameter]
    public int OverscanColumns { get; set; } = 2;

    private double MouseX { get; set; }
    private double MouseXStart { get; set; }
    private int ActiveResizerIndex { get; set; }
    private bool IsDragging { get; set; }
    private double CurrentColResizeAmount { get; set; }
    private int _minResizeWidth = 15;
    private IWindowEventService _windowEventService = null!;

    private Region LeftHeadingRegion => DatasheetViewRegionCalculator.GetFrozenLeftRegion(_viewRegion, _sheet.NumCols, _sheet.FreezeState.Left);

    private Region MainHeadingRegion => new(0, 0, MainLeft, MainRight);

    private Region RightHeadingRegion => DatasheetViewRegionCalculator.GetFrozenRightRegion(_viewRegion, _sheet.NumCols, _sheet.FreezeState.Right);

    private int MainLeft => Math.Clamp(Math.Max(_sheet.FreezeState.Left, _viewRegion.Left), _viewRegion.Left, _viewRegion.Right);
    private int MainRight => Math.Clamp(Math.Min(_sheet.NumCols - _sheet.FreezeState.Right - 1, _viewRegion.Right), MainLeft, _viewRegion.Right);

    protected override void OnInitialized()
    {
        _windowEventService = new WindowEventService(Js);
        base.OnInitialized();
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _windowEventService.RegisterMouseEvent("mouseup", WindowEventServiceOnOnMouseUp, 15);
            await _windowEventService.RegisterMouseEvent("mousemove", WindowHandleMouseMove, 15);
        }
    }

    public Task<bool> WindowHandleMouseMove(MouseEventArgs arg)
    {
        MouseX = arg.PageX;
        if (IsDragging)
        {
            CurrentColResizeAmount = MouseX - MouseXStart;
            UpdateResizePreviewItem();
            StateHasChanged();
            return Task.FromResult(true);
        }

        return Task.FromResult(false);
    }

    private void UpdateResizePreviewItem()
    {
        if (PreviewService == null)
            return;

        var resizeWidth = Math.Max(_minResizeWidth, _sheet.Columns.GetVisualWidth(ActiveResizerIndex) + CurrentColResizeAmount);
        var x = _sheet.Columns.GetVisualLeft(ActiveResizerIndex) + resizeWidth;
        var totalHeight = _sheet.Rows.GetVisualTop(_sheet.NumRows);

        var newItem = new PreviewItem
        {
            Coord = new PixelCoord(x, 0, 2, totalHeight),
            BorderColor = "black",
            BorderThickness = "1px",
            BorderStyle = "solid",
            ZIndex = 4
        };
        PreviewService.Update(_resizePreviewItem, newItem);
        _resizePreviewItem = newItem;
    }

    private void RemoveResizePreviewItem()
    {
        if (_resizePreviewItem != null && PreviewService != null)
        {
            PreviewService.Remove(_resizePreviewItem);
            _resizePreviewItem = null;
        }
    }

    private void HandleMouseDownOnResizer(int col)
    {
        MouseXStart = MouseX;
        ActiveResizerIndex = col;
        CurrentColResizeAmount = 0;
        IsDragging = true;
    }

    private async Task<bool> WindowEventServiceOnOnMouseUp(MouseEventArgs arg)
    {
        if (IsDragging)
        {
            RemoveResizePreviewItem();
            IsDragging = false;
            var resizeWidth = Math.Max(_minResizeWidth, _sheet.Columns.GetVisualWidth(ActiveResizerIndex) + CurrentColResizeAmount);
            if (_sheet.Selection.Regions.All(x => x is ColumnRegion) && _sheet.Selection.Regions.Any(x => x.SpansCol(ActiveResizerIndex)))
            {
                _sheet.Commands.BeginCommandGroup();
                foreach (var region in _sheet.Selection.Regions.Cast<ColumnRegion>())
                {
                    for (int i = region.Left; i <= region.Right; i++)
                    {
                        _sheet.Columns.SetSize(i, resizeWidth);
                    }
                }

                _sheet.Commands.EndCommandGroup();
            }
            else
            {
                _sheet.Columns.SetSize(ActiveResizerIndex, resizeWidth);
            }

            await RefreshHeadingViews();

            return true;
        }

        return false;
    }

    private async Task RefreshHeadingViews()
    {
        if (_leftView != null)
            await _leftView.RefreshView();

        if (MainView != null)
            await MainView.RefreshView();

        if (_rightView != null)
            await _rightView.RefreshView();
    }

    private bool HasVisibleCols(Region? region) => _sheet.HasVisibleCols(region);

    public async ValueTask DisposeAsync()
    {
        await _windowEventService.DisposeAsync();
    }

}

@using BlazorDatasheet.DataStructures.Geometry
@using BlazorDatasheet.Extensions
@using BlazorDatasheet.Menu
@using BlazorDatasheet.Render
@using BlazorDatasheet.Render.AutoScroll
@using BlazorDatasheet.Render.DefaultComponents
@using BlazorDatasheet.Render.Headings
@using ColumnHeadingRenderer = BlazorDatasheet.Render.Headings.ColumnHeadingRenderer
@inherits SheetComponentBase

<CascadingValue Value="@ScrollServiceForCascade" IsFixed="true">
    <div class="vars"
         theme="@_theme"
         style="--gutter-top-height: @GetGutterSize(Axis.Col)px; --gutter-left-width:@GetGutterSize(Axis.Row)px;">

        <SheetMenuTarget MenuId="SelectionMenu"
                         MenuData="_sheet"
                         Margin="0"
                         DisableMenuTarget="!_menuOptions.ContextMenuEnabled"
                         Trigger="@MenuTrigger.OnContextMenu"
                         Placement="@MenuPlacement.BottomRight">

            <div
                @onmouseover="SetMouseOver" @onmouseout="SetMouseOut" class="bds-sheet"
                style="width:@(TotalViewWidth)px; height:@(TotalViewHeight)px;"
                @ref="_sheetContainer">
                <div class="bds-sheet-layout" style="display: flex; flex-direction: column; align-items:flex-start;">

                    @if (ShowColHeadings)
                    {
                        <div class="bds-sheet-col-head-container"
                             style="z-index: @ColumnHeadingZIndex; @(StickyHeaders ? "position: sticky; top: 0;" : "")">
                            <div class="bds-sheet-header-row" style="display: flex; align-items: start;">

                                @if (ShowRowHeadings)
                                {
                                    <div class="bds-sheet-cell bds-row-head bds-col-head" data-row="-1" data-col="-1"
                                         style="
                                             width: @(_sheet.Rows.HeadingWidth)px;
                                         background: var(--col-header-bg-color);
                                         z-index: @CornerHeadingZIndex;
                                         @(StickyHeaders ? "position: sticky; top: 0; left:0;" : "")
                                         height: @(_sheet.Columns.HeadingHeight)px;">
                                    </div>
                                }

                                <ColumnHeadingRenderer
                                    OverscanColumns="OverscanColumns"
                                    ViewRegion="_viewRegion"
                                    Sheet="_sheet"
                                    ShowColumnMenu="_menuOptions.HeaderMenuEnabled"
                                    PreviewService="_previewService">
                                    @ColumnHeaderTemplate(context)
                                </ColumnHeadingRenderer>
                            </div>
                        </div>
                    }

                    @{
                        var hasVisibleRows = _sheet.Rows.CountVisible(_viewRegion.Top, _viewRegion.Bottom) > 0;
                        var hasVisibleCols = _sheet.Columns.CountVisible(_viewRegion.Left, _viewRegion.Right) > 0;
                    }
                    @if (!hasVisibleCols && !hasVisibleRows)
                    {
                        <div></div>
                    }
                    else if (!hasVisibleRows)
                    {
                        @EmptyRowsTemplate
                    }
                    else if (!hasVisibleCols)
                    {
                        @EmptyColumnsTemplate
                    }

                    <div class="bds-sheet-main-row" style="display: flex; align-items: start;">
                        @if (ShowRowHeadings)
                        {
                            <div class="bds-sheet-row-head-container"
                                 style="z-index: @RowHeadingZIndex; @(StickyHeaders ? "position: sticky; left: 0;" : "")">
                                <RowHeadingRenderer
                                    OverscanRows="OverscanRows"
                                    ViewRegion="_viewRegion"
                                    Sheet="_sheet">
                                    @RowHeaderTemplate(context)
                                </RowHeadingRenderer>
                            </div>
                        }

                        <AutoScroller
                            Options="AutoScrollOptions"
                            State="_autoScrollState"
                            Enabled="@UseAutoScroll"/>

                        <CascadingValue Value="_paneContext" IsFixed="false">
                            <div class="bds-sheet-pane-rows"
                                 style="display: flex; flex-direction: column; align-items: start;">
                                @if (_sheet.FreezeState.Top > 0)
                                {
                                    <div class="bds-frozen-top"
                                         style="z-index: @(PaneRowZIndex + 1); top: @(TopMainContentOffset)px;">
                                        <DatasheetPaneRow
                                            ViewRegion="@(_sheet.GetFrozenTopRegion())"
                                            @ref="_topPaneRow"
                                            OverscanColumns="OverscanColumns"
                                            OverscanRows="OverscanRows"
                                            EditorLayerChanged="RegisterEditorLayer"
                                            AutofitLayerChanged="RegisterAutofitLayer"/>
                                    </div>
                                }

                                <DatasheetPaneRow
                                    @ref="_mainPaneRow"
                                    ViewRegion="@(new Region(_viewRegion.Top + _sheet.FreezeState.Top, _viewRegion.Bottom - _sheet.FreezeState.Bottom, _viewRegion.Left, _viewRegion.Right))"
                                    OverscanColumns="OverscanColumns"
                                    OverscanRows="OverscanRows"
                                    EditorLayerChanged="RegisterEditorLayer"
                                    AutofitLayerChanged="RegisterAutofitLayer"/>

                                @if (_sheet.FreezeState.Bottom > 0)
                                {
                                    <div class="bds-frozen-bottom" style="z-index: @(PaneRowZIndex + 1); bottom: 0;">
                                        <DatasheetPaneRow
                                            ViewRegion="_sheet.GetFrozenBottomRegion()"
                                            @ref="_bottomPaneRow"
                                            OverscanColumns="OverscanColumns"
                                            OverscanRows="OverscanRows"
                                            EditorLayerChanged="RegisterEditorLayer"
                                            AutofitLayerChanged="RegisterAutofitLayer"/>
                                    </div>
                                }
                            </div>
                        </CascadingValue>
                    </div>

                </div>
            </div>

        </SheetMenuTarget>

        <SelectionMenu
            MenuOptions="_menuOptions"
            Disabled="@IsReadOnly"
            DefaultFilterTypes="DefaultFilterTypes"/>

    </div>
</CascadingValue>


@code{

    /// <summary>
    /// Set this to render a custom column heading
    /// </summary>
    [Parameter]
    public RenderFragment<HeadingContext> ColumnHeaderTemplate { get; set; } =
        context => @<div>@context.Heading</div>;

    /// <summary>
    /// Set this to render a custom row heading
    /// </summary>
    [Parameter]
    public RenderFragment<HeadingContext> RowHeaderTemplate { get; set; } =
        context => @<div>@(context.Heading ?? (context.Index + 1).ToString())</div>;

    /// <summary>
    /// Render fragment shown when no columns are visible.
    /// </summary>
    [Parameter]
    public RenderFragment EmptyColumnsTemplate { get; set; } =
        @<div class="bds-sheet-row-head-container bds-sheet-cell">No visible columns.</div>;

    /// <summary>
    /// Render fragment shown when no rows are visible.
    /// </summary>
    [Parameter]
    public RenderFragment EmptyRowsTemplate { get; set; } =
        @<div class="bds-sheet-row-head-container bds-sheet-cell">No visible rows.</div>;

    private RenderFragment<VisualCell>? CellRenderFragment { get; set; }

    private RenderFragment GetIconRenderFragment(string? cellIcon)
    {
        if (cellIcon != null && Icons.TryGetValue(cellIcon, out var rf))
            return rf;
        return _ => { };
    }

    private Type GetCellRendererType(string type)
    {
        if (CustomCellTypeDefinitions.TryGetValue(type, out var definition))
            return definition.RendererType;

        return typeof(TextRenderer);
    }

    private double LeftMainContentOffset => StickyHeaders ? this.GetGutterSize(Axis.Row) : 0;
    private double TopMainContentOffset => StickyHeaders ? this.GetGutterSize(Axis.Col) : 0;


    private RenderFragment<VisualCell> CreateComponent() => cell => builder =>
    {
        var dataRow = cell.Merge != null ? cell.VisibleMergeRowStart : cell.Row;
        var dataCol = cell.Merge != null ? cell.VisibleMergeColStart : cell.Col;

        builder.OpenElement(20, "div");
        builder.AddAttribute(30, "data-row", dataRow);
        builder.AddAttribute(40, "data-col", dataCol);
        builder.AddAttribute(50, "class", "bds-sheet-cell");
        var cellStyle = cell.FormatStyleString;
        if (!string.IsNullOrEmpty(cellStyle))
            builder.AddAttribute(60, "style", cell.FormatStyleString);

        if (cell.Icon != null)
        {
            builder.OpenElement(70, "div");
            builder.AddAttribute(80, "style", $"margin-right:2px; flex-shrink: 1; float:left; color: {cell.Format?.IconColor ?? "var(--icon-color)"};");
            builder.AddContent(90, GetIconRenderFragment(cell.Icon));
            builder.CloseElement();
        }

        builder.OpenElement(100, "div");
        builder.AddAttribute(110, "class", "bds-cell-container");

        switch (cell.CellType)
        {
            case "default":
            case "text":
            case "datetime":
                builder.AddContent(120, cell.FormattedString);
                break;
            case "boolean":
                builder.OpenComponent(120, typeof(BoolRenderer));
                builder.AddComponentParameter(140, nameof(BaseRenderer.Cell), cell);
                builder.AddComponentParameter(160, nameof(BaseRenderer.Sheet), _sheet);
                builder.AddComponentParameter(180, nameof(BaseRenderer.IsReadonly), IsReadOnly);
                builder.CloseComponent();
                break;
            case "select":
                builder.OpenComponent(120, typeof(SelectRenderer));
                builder.AddComponentParameter(140, nameof(BaseRenderer.Cell), cell);
                builder.AddComponentParameter(160, nameof(BaseRenderer.Sheet), _sheet);
                builder.AddComponentParameter(180, nameof(BaseRenderer.IsReadonly), IsReadOnly);
                builder.CloseComponent();
                break;
            default:
                builder.OpenComponent(120, GetCellRendererType(cell.CellType));
                builder.AddComponentParameter(140, nameof(BaseRenderer.Cell), cell);
                builder.AddComponentParameter(160, nameof(BaseRenderer.Sheet), _sheet);
                builder.AddComponentParameter(180, nameof(BaseRenderer.IsReadonly), IsReadOnly);
                builder.CloseComponent();
                break;
        }

        builder.CloseElement();
        builder.CloseElement();
    };

    private void CreateCellRenderFragment() => CellRenderFragment = CreateComponent();

    private void SetMouseOut() => IsMouseInsideSheet = false;

    private void SetMouseOver() => IsMouseInsideSheet = true;

}

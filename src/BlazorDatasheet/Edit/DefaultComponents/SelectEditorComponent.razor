@using BlazorDatasheet.Core.Util
@using BlazorDatasheet.Core.Interfaces
@using BlazorDatasheet.Core.Data
@using BlazorDatasheet.Core.Edit
@using BlazorDatasheet.Core.Validation
@using BlazorDatasheet.Render.Popover
@inherits BaseEditor

<div class="bds-select-editor" id="@_anchorId">
    <TextEditorComponent @ref="_textEditor"
                         Style="@Style"
                         CellWidth="@CellWidth"
                         CellHeight="@CellHeight"
                         OnValueChanged="OnTextValueChanged"/>
</div>

<BdsPopover AnchorId="@_anchorId" IsOpen="@_dropdownOpen" CssClass="bds-select-dropdown-popover">
    @if (_filteredValues.Length == 0)
    {
        <div class="bds-select-item bds-select-item-empty" aria-disabled="true">
            No matches
        </div>
    }
    else
    {
        @foreach (var val in _filteredValues)
        {
            <div class="bds-select-item @(val.Equals(_currentSelected) ? "active" : "")"
                 title="@val"
                 @onmouseup="() => SelectItem(val)">
                @val
            </div>
        }
    }
</BdsPopover>

@code {

    private TextEditorComponent _textEditor = default!;
    internal TextEditorComponent? TextEditor => _textEditor;
    private Sheet _sheet = null!;
    private string[] _allValues = Array.Empty<string>();
    private string[] _filteredValues = Array.Empty<string>();
    private string? _currentSelected;
    private bool _dropdownOpen;

    private readonly string _anchorId = $"bds-select-anchor-{Guid.NewGuid():N}";

    public override void BeforeEdit(IReadOnlyCell cell, Sheet sheet)
    {
        _sheet = sheet;

        foreach (var validator in sheet.Validators.Get(cell.Row, cell.Col))
        {
            if (validator is SourceValidator sourceValidator)
            {
                _allValues = sourceValidator.ValidationSource.ToArray();
                break;
            }
        }

        _filteredValues = _allValues;
        _textEditor.BeforeEdit(cell, sheet);
    }

    public override void BeginEdit(EditEntryMode entryMode, string? editValue, string key)
    {
        _textEditor.BeginEdit(entryMode, editValue, key);
        CurrentValue = _textEditor.CurrentValue;

        if (entryMode == EditEntryMode.Key)
        {
            FilterDropdown();
            AutoSelectFirst();
        }
        else
        {
            _filteredValues = _allValues;
        }

        OpenDropdown();
    }

    private void OnTextValueChanged(string value)
    {
        CurrentValue = value;

        SyncDropdownToCurrentValue();

        StateHasChanged();
    }

    public override void HandleEditValueChange(string? s)
    {
        base.HandleEditValueChange(s);
        _textEditor?.HandleEditValueChange(s);

        SyncDropdownToCurrentValue();

        StateHasChanged();
    }

    private void SyncDropdownToCurrentValue()
    {
        if (_textEditor.IsFormulaValue)
        {
            CloseDropdown();
            return;
        }

        FilterDropdown();
        AutoSelectFirst();

        if (!_dropdownOpen)
            OpenDropdown();
    }

    private void FilterDropdown()
    {
        if (string.IsNullOrWhiteSpace(CurrentValue))
        {
            _filteredValues = _allValues;
            return;
        }

        var upper = CurrentValue.ToUpperInvariant();
        _filteredValues = _allValues.Where(v => v.ToUpperInvariant().Contains(upper)).ToArray();
    }

    private void AutoSelectFirst()
    {
        if (_filteredValues.Length > 0)
        {
            var upper = (CurrentValue ?? string.Empty).ToUpperInvariant();
            _currentSelected = _filteredValues.FirstOrDefault(v => v.ToUpperInvariant().StartsWith(upper))
                               ?? _filteredValues[0];
        }
        else
        {
            _currentSelected = null;
        }
    }

    public override bool HandleKey(string key, bool ctrlKey, bool shiftKey, bool altKey, bool metaKey)
    {
        // In formula mode, delegate everything to the text editor
        if (_textEditor.IsFormulaValue)
        {
            var handled = _textEditor.HandleKey(key, ctrlKey, shiftKey, altKey, metaKey);
            CurrentValue = _textEditor.CurrentValue;
            return handled;
        }

        if (KeyUtil.IsEnter(key))
        {
            if (!string.IsNullOrWhiteSpace(_currentSelected))
            {
                SelectItem(_currentSelected);
                return true;
            }

            return false;
        }

        if (KeyUtil.IsKeyDown(key) && _dropdownOpen)
        {
            HoverItem(1);
            return true;
        }

        if (KeyUtil.IsKeyUp(key) && _dropdownOpen)
        {
            HoverItem(-1);
            return true;
        }

        if (key == "Escape" && _dropdownOpen)
        {
            CloseDropdown();
            return true;
        }

        // Let the text editor handle other keys (typing)
        var result = _textEditor.HandleKey(key, ctrlKey, shiftKey, altKey, metaKey);
        CurrentValue = _textEditor.CurrentValue;
        return result;
    }

    public override bool HandleMouseDown(int row, int col, bool ctrlKey, bool shiftKey, bool altKey, bool metaKey)
    {
        return _textEditor.HandleMouseDown(row, col, ctrlKey, shiftKey, altKey, metaKey);
    }

    public override bool HandleMouseOver(int row, int col, bool ctrlKey, bool shiftKey, bool altKey, bool metaKey)
    {
        return _textEditor.HandleMouseOver(row, col, ctrlKey, shiftKey, altKey, metaKey);
    }

    public override async Task<bool> HandleWindowMouseUpAsync()
    {
        return await _textEditor.HandleWindowMouseUpAsync();
    }

    private void HoverItem(int direction)
    {
        if (_filteredValues.Length == 0)
            return;

        var index = !string.IsNullOrWhiteSpace(_currentSelected)
            ? Array.IndexOf(_filteredValues, _currentSelected)
            : -1;

        index = direction > 0
            ? Math.Min(index + 1, _filteredValues.Length - 1)
            : Math.Max(index - 1, 0);

        _currentSelected = _filteredValues[index];
        StateHasChanged();
    }

    private void SelectItem(string item)
    {
        CurrentValue = item;
        CloseDropdown();
        AcceptEdit();
    }

    private void OpenDropdown()
    {
        if (_textEditor.IsFormulaValue)
            return;

        _dropdownOpen = true;
        StateHasChanged();
    }

    private void CloseDropdown()
    {
        if (!_dropdownOpen)
            return;

        _dropdownOpen = false;
        StateHasChanged();
    }

}

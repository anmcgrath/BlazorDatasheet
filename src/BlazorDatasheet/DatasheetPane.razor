@using BlazorDatasheet.Core.Data
@using BlazorDatasheet.Core.Events.Visual
@using BlazorDatasheet.Core.Layout
@using BlazorDatasheet.DataStructures.Geometry
@using BlazorDatasheet.Render.AutoScroll
@using BlazorDatasheet.Render
@using BlazorDatasheet.Render.Layers
@using BlazorDatasheet.Services
@using BlazorDatasheet.Virtualise

@implements IAsyncDisposable

@if (Sheet.HasVisibleCells(ViewRegion))
{
    if (RenderAutoScroller)
    {
        <AutoScroller
            Options="AutoScrollOptions"
            IsActive="IsAutoScrollActive"
            Enabled="@UseAutoScroll"/>
    }

    <LayerContainer
        Sheet="Sheet"
        ViewRegion="@ViewRegion"
        PointerInputService="PointerInputService">
        <HighlightLayer/>
        @if (UseAutoFill && !IsReadOnly)
        {
            <AutofillLayer AutofillDraggingChanged="AutofillDraggingChanged"/>
        }
        @if (RenderAutofitLayer)
        {
            <AutofitLayer
                @ref="_autofitLayer"
                AutoFitOnInteraction="AutoFit"
                NumberOfSignificantDigits="NumberPrecisionDisplay"
                CellRenderFragment="CellRenderFragment"/>
        }
        <VirtualMergesLayer
            CellRenderFragment="CellRenderFragment"
            NumberPrecisionDisplay="NumberPrecisionDisplay"
            Cache="_visualCellCache"/>

        <EditorLayer Disabled="@IsReadOnly" @ref="_editorLayer"
                     CustomCellTypes="@CustomCellTypeDefinitions"/>

        <SelectionRendererLayer/>
        @if (ShowFormulaDependents)
        {
            <FormulaDependenciesLayer/>
        }
    </LayerContainer>

    <Virtualise2D
        OverscanColumns="OverscanColumns"
        OverscanRows="OverscanRows"
        Class="@CssClass"
        OnViewportChanged="HandleVirtualViewportChanged"
        LayoutProvider="_cellLayoutProvider"
        ViewRegion="ViewRegion"
        RowClass="bds-row"
        @ref="_mainView"
        Context="vr">
        <RowTemplate>
            <DatasheetGridRow
                NumberPrecisionDisplay="NumberPrecisionDisplay"
                Row="vr.Row"
                CellRenderFragment="CellRenderFragment"
                VisibleColIndices="vr.VisibleColIndices"
                Sheet="Sheet"
                Cache="_visualCellCache"
                IsDirty="IsRowDirty(vr.Row)"/>
        </RowTemplate>
    </Virtualise2D>
}

@code {

    /// <summary>
    /// The sheet, which may change.
    /// </summary>
    [Parameter, EditorRequired]
    public Sheet Sheet { get; set; } = null!;

    private Sheet? _sheet;

    /// <summary>
    /// The the view that this pane will handle
    /// </summary>
    [Parameter, EditorRequired]
    public required IRegion ViewRegion { get; set; } = null!;

    private IGridLayoutProvider _cellLayoutProvider = null!;

    [Parameter, EditorRequired] public RenderFragment<VisualCell> CellRenderFragment { get; set; } = null!;
    [Parameter, EditorRequired] public Dictionary<string, CellTypeDefinition> CustomCellTypeDefinitions { get; set; } = null!;
    [Parameter, EditorRequired] public EventCallback<bool> AutofillDraggingChanged { get; set; }
    [Parameter, EditorRequired] public Func<bool> IsAutoScrollActive { get; set; } = () => false;
    [Parameter, EditorRequired] public AutoScrollOptions AutoScrollOptions { get; set; } = null!;
    [Parameter] public SheetPointerInputService? PointerInputService { get; set; }
    [Parameter] public int GridLevel { get; set; }
    [Parameter] public int OverscanColumns { get; set; } = 2;
    [Parameter] public int OverscanRows { get; set; } = 6;
    [Parameter] public int NumberPrecisionDisplay { get; set; } = 13;
    [Parameter] public bool ShowFormulaDependents { get; set; }
    [Parameter] public bool UseAutoFill { get; set; } = true;
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool UseAutoScroll { get; set; }
    [Parameter] public bool AutoFit { get; set; }
    [Parameter] public bool RenderAutoScroller { get; set; }
    [Parameter] public bool RenderAutofitLayer { get; set; }
    [Parameter] public string CssClass { get; set; } = string.Empty;
    [Parameter] public Action<EditorLayer?, bool>? EditorLayerChanged { get; set; }
    [Parameter] public Action<AutofitLayer?>? AutofitLayerChanged { get; set; }

    private Virtualise2D? _mainView;
    private EditorLayer? _editorLayer;
    private AutofitLayer? _autofitLayer;


    private readonly List<IRegion> _dirtyRegions = new();
    private readonly HashSet<int> _dirtyRowIndices = new();
    private Dictionary<CellPosition, VisualCell> _visualCellCache = new();


    protected override void OnParametersSet()
    {
        if (_sheet == null || _sheet != Sheet)
        {
            RemoveSheetEvents();

            _sheet = Sheet;

            _cellLayoutProvider = new CellLayoutProvider(Sheet, ViewRegion);
            _visualCellCache.Clear();

            AddSheetEvents();
        }

        _cellLayoutProvider.ViewRegion = ViewRegion;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            EditorLayerChanged?.Invoke(_editorLayer, true);
            AutofitLayerChanged?.Invoke(_autofitLayer);
        }

        ClearDirty();

        base.OnAfterRender(firstRender);
    }

    private void ClearDirty()
    {
        _dirtyRegions.Clear();
        _dirtyRowIndices.Clear();
    }

    private void HandleVirtualViewportChanged(VirtualViewportChangedEventArgs args)
    {
        foreach (var region in args.RemovedRegions)
        {
            foreach (var position in region)
            {
                _visualCellCache.Remove(position);
            }
        }

        MakeRegionsDirty(args.NewRegions);
    }

    private void SheetOnSheetDirty(object? sender, DirtySheetEventArgs e)
    {
        var dirtyRegions = e.DirtyRows
            .GetAllIntervalData()
            .Select(x => new RowRegion(x.interval.Start, x.interval.End))
            .ToList();

        if (dirtyRegions.Count > 0)
            MakeRegionsDirty(dirtyRegions);
    }


    private void MakeRegionsDirty(IEnumerable<IRegion?> dirtyRegions)
    {
        if (_sheet == null)
            return;

        foreach (var region in dirtyRegions)
        {
            var boundedRegion = region?.GetIntersection(ViewRegion) as Region;
            if (boundedRegion == null)
                continue;

            var visibleCols = new List<int>();
            foreach (var col in _sheet.Columns.GetVisibleIndices(boundedRegion.Left, boundedRegion.Right))
                visibleCols.Add(col);

            if (visibleCols.Count == 0)
                continue;

            _dirtyRegions.Add(boundedRegion);

            foreach (var row in _sheet.Rows.GetVisibleIndices(boundedRegion.Top, boundedRegion.Bottom))
            {
                _dirtyRowIndices.Add(row);
                foreach (var col in visibleCols)
                {
                    var position = new CellPosition(row, col);
                    var visualCell = new VisualCell(row, col, _sheet, NumberPrecisionDisplay);

                    if (!_visualCellCache.TryAdd(position, visualCell))
                        _visualCellCache[position] = visualCell;
                }
            }
        }

        StateHasChanged();
    }

    private bool IsRowDirty(int rowIndex)
    {
        return _dirtyRowIndices.Contains(rowIndex);
    }

    private void AddSheetEvents()
    {
        if (_sheet == null)
            return;

        _sheet.SheetDirty += SheetOnSheetDirty;
    }

    private void RemoveSheetEvents()
    {
        if (_sheet == null)
            return;

        _sheet.SheetDirty -= SheetOnSheetDirty;
    }

    public async Task RefreshView()
    {
        if (_mainView != null)
            await _mainView.RefreshView();
    }

    public async ValueTask DisposeAsync()
    {
        RemoveSheetEvents();
        if (_mainView != null) await _mainView.DisposeAsync();
        if (_autofitLayer != null) await ((IAsyncDisposable)_autofitLayer).DisposeAsync();
    }

}

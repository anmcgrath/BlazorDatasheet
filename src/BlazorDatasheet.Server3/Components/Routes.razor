@using Index = BlazorDatasheet.SharedPages.Pages.Index
<Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="new[] { typeof(Index).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(SharedPages.MainLayout)"/>
        <FocusOnNavigate RouteData="routeData" Selector="h1"/>
    </Found>
</Router>